# ===== API Keys =====
# Note: In production, users provide their own API keys via the web interface.
# These server-side keys are optional and only used for CLI or testing.

# Optional: Server-side API Keys (not required for web interface)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Optional API Keys (for data sources)
ALPHA_VANTAGE_API_KEY=
FINMIND_API_KEY=


# ===== Security Configuration =====

# JWT Secret - IMPORTANT: Change this in production!
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=dev-secret-please-change-in-production

# CORS Origins - Comma-separated list of allowed frontend URLs
# Example: CORS_ORIGINS=https://your-app.railway.app,https://your-frontend.vercel.app
# Leave empty to use default wildcard origins (less secure)
CORS_ORIGINS=

# Google OAuth (optional - for user authentication and persistent storage)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000


# ===== Deployment Configuration =====
TRADINGAGENTS_RESULTS_DIR=/app/results
PYTHON_VERSION=3.13

# Frontend Configuration (for deployment)
NEXT_PUBLIC_API_URL=http://localhost:8000


# ===== Watchlist: Telegram Bot =====
# Get token from @BotFather; get chat ID from @userinfobot or the getUpdates API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ===== Watchlist: Google Sheets (GCP Service Account) =====
# Paste the full service account JSON as a single line (or base64-encode it)
GOOGLE_SERVICE_ACCOUNT_JSON=
# The spreadsheet ID from its URL: /spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=


# ===== Watchlist: Auto-Analysis Scheduler =====
# Cron expression for daily analysis (5 fields: min hour day month weekday)
# Example: "0 9 * * 1-5" = 9am UTC, Monday-Friday
# Leave empty to disable scheduled auto-analysis (manual trigger still works)
WATCHLIST_ANALYSIS_CRON=0 9 * * 1-5

# LLM used for server-side watchlist analysis (no browser needed)
WATCHLIST_DEEP_THINK_LLM=qwen2.5:14b-16k
WATCHLIST_QUICK_THINK_LLM=qwen2.5:14b-16k
WATCHLIST_DEEP_THINK_BASE_URL=http://localhost:11434/v1
WATCHLIST_QUICK_THINK_BASE_URL=http://localhost:11434/v1
WATCHLIST_DEEP_THINK_API_KEY=ollama
WATCHLIST_QUICK_THINK_API_KEY=ollama
WATCHLIST_ANALYSTS=market,fundamentals,quant
WATCHLIST_REPORT_LANGUAGE=zh-TW